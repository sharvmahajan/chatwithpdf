# ==============================================================================
# API KEYS
# ==============================================================================
# Google AI Studio Gemini API Key (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# ==============================================================================
# APP CONFIGURATION
# ==============================================================================
APP_NAME=AntigravityRAG
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ==============================================================================
# PATHS
# ==============================================================================
DATA_DIR=data
UPLOAD_DIR=data/uploaded_pdfs
VECTOR_INDEX_DIR=data/vector_index
CACHE_DIR=data/cache

# ==============================================================================
# MODEL CONFIGURATION
# ==============================================================================
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
# Use gemini-2.0-flash — stable, fast, and supported by the google-genai SDK.
# Do NOT use gemini-1.5-pro-latest (deprecated) or gemini-3.x (preview/unstable).
GEMINI_MODEL_NAME=gemini-2.0-flash

# ==============================================================================
# RAG PARAMETERS
# ==============================================================================
CHUNK_SIZE=600
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=25
TOP_K_RERANK=5
SCORE_THRESHOLD=0.1
HYDE_ENABLED=true
